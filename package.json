{
  "name": "points-accelerator",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/backend",
    "apps/frontend"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "dev:backend": "npm --workspace apps/backend run dev",
    "dev:frontend": "npm --workspace apps/frontend run dev",
    "dev:design": "npm --workspace apps/frontend run dev:design",
    "build": "npm-run-all build:*",
    "build:backend": "npm --workspace apps/backend run build",
    "build:frontend": "npm --workspace apps/frontend run build",
    "test": "npm-run-all test:*",
    "test:backend": "npm --workspace apps/backend run test",
    "test:frontend": "npm --workspace apps/frontend run test",
    "e2e": "npm --workspace apps/frontend run e2e",
    "lint": "npm-run-all lint:*",
    "lint:backend": "npm --workspace apps/backend run lint",
    "lint:frontend": "npm --workspace apps/frontend run lint",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
