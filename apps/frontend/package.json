{
  "name": "@economy-rice/frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:design": "VITE_DESIGN_PREVIEW=true vite",
    "build": "tsc --noEmit -p tsconfig.json && vite build",
    "preview": "vite preview",
