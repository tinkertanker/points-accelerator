generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LedgerEntryType {
  MESSAGE_REWARD
  MANUAL_AWARD
  MANUAL_DEDUCT
  CORRECTION
  TRANSFER
  DONATION
  SHOP_REDEMPTION
  ADJUSTMENT
  SUBMISSION_REWARD
  BET_WIN
  BET_LOSS
}

enum SubmissionStatus {
  PENDING
  APPROVED
  OUTSTANDING
  REJECTED
}

enum RedemptionStatus {
  AWAITING_APPROVAL
  PENDING
  FULFILLED
  CANCELED
}

enum RedemptionMode {
  INDIVIDUAL
  GROUP
}

enum ShopItemAudience {
  INDIVIDUAL
  GROUP
}

enum ParticipantCurrencyEntryType {
  MESSAGE_REWARD
  MANUAL_AWARD
  MANUAL_DEDUCT
  CORRECTION
  TRANSFER
  DONATION
  SHOP_REDEMPTION
  SUBMISSION_REWARD
  BET_WIN
  BET_LOSS
}

model GuildConfig {
  id                           String                @id @default(cuid())
  guildId                      String                @unique
  appName                      String                @default("points accelerator")
  pointsName                   String                @default("points")
  pointsSymbol                 String                @default("🏅")
  currencyName                 String                @default("rice")
  currencySymbol               String                @default("💲")
  groupPointsPerCurrencyDonation Decimal             @default(10) @db.Decimal(18, 6)
  mentorRoleIds                String[]              @default([])
  publicLeaderboardToken       String?               @unique
  passivePointsReward          Decimal               @default(1) @db.Decimal(18, 6)
  passiveCurrencyReward        Decimal               @default(1) @db.Decimal(18, 6)
  passiveCooldownSeconds       Int                   @default(60)
  passiveMinimumCharacters     Int                   @default(4)
  passiveAllowedChannelIds     String[]              @default([])
  passiveDeniedChannelIds      String[]              @default([])
  commandLogChannelId          String?
  redemptionChannelId          String?
  listingChannelId             String?
  announcementsChannelId       String?
  lastAnnouncedVersion         String?
  betWinChance                 Int                   @default(50)
  bettingCooldownSeconds       Int                   @default(0)
  createdAt                    DateTime              @default(now())
  updatedAt                    DateTime              @updatedAt
  groups                       Group[]
  roleCapabilities             DiscordRoleCapability[]
  shopItems                    ShopItem[]
  ledgerEntries                LedgerEntry[]
  marketplaceListings          MarketplaceListing[]
  shopRedemptions              ShopRedemption[]
  participantCurrencyEntries   ParticipantCurrencyEntry[]
  auditLogs                    AuditLog[]
  participants                 Participant[]
  assignments                  Assignment[]
  submissions                  Submission[]
}

model Group {
  id             String        @id @default(cuid())
  guildId        String
  displayName    String
  slug           String
  mentorName     String?
  roleId         String
  active         Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  guild          GuildConfig   @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  aliases        GroupAlias[]
  ledgerSplits            LedgerSplit[]
  shopRedemptions         ShopRedemption[]
  participants            Participant[]
  submissions             Submission[]
  @@unique([guildId, slug])
  @@unique([guildId, roleId])
  @@index([guildId, active, displayName])
}

model GroupAlias {
  id        String   @id @default(cuid())
  groupId    String
  value      String
  createdAt  DateTime @default(now())
  group      Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, value])
}

model DiscordRoleCapability {
  id                  String      @id @default(cuid())
  guildId             String
  roleId              String
  roleName            String
  canManageDashboard  Boolean     @default(false)
  canAward            Boolean     @default(false)
  maxAward            Decimal?    @db.Decimal(18, 6)
  actionCooldownSeconds Int?
  canDeduct           Boolean     @default(false)
  canMultiAward       Boolean     @default(false)
  canSell             Boolean     @default(false)
  canReceiveAwards    Boolean     @default(true)
  isGroupRole         Boolean     @default(false)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  guild               GuildConfig @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  @@unique([guildId, roleId])
}

model LedgerEntry {
  id                String          @id @default(cuid())
  guildId           String
  type              LedgerEntryType
  description       String
  createdByUserId   String?
  createdByUsername String?
  externalRef       String?
  createdAt         DateTime        @default(now())
  guild             GuildConfig     @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  splits            LedgerSplit[]
  shopRedemption    ShopRedemption?

  @@index([guildId, createdAt(sort: Desc)])
  @@index([guildId, externalRef])
}

model LedgerSplit {
  id            String      @id @default(cuid())
  entryId        String
  groupId        String
  pointsDelta    Decimal     @db.Decimal(18, 6)
  currencyDelta  Decimal     @db.Decimal(18, 6)
  createdAt      DateTime    @default(now())
  entry          LedgerEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  group          Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId, createdAt(sort: Desc)])
  @@index([entryId])
}

model ShopItem {
  id                     String            @id @default(cuid())
  guildId                String
  name                   String
  description            String
  audience               ShopItemAudience  @default(INDIVIDUAL)
  cost                   Decimal           @db.Decimal(18, 6)
  stock                  Int?
  enabled                Boolean           @default(true)
  fulfillmentInstructions String?
  emoji                  String            @default("💸")
  ownerUserId            String?
  ownerUsername          String?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  guild                  GuildConfig       @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  redemptions            ShopRedemption[]

  @@index([guildId, enabled, name])
}

model ShopRedemption {
  id                String           @id @default(cuid())
  guildId           String
  shopItemId        String
  groupId           String
  requestedByParticipantId String?
  requestedByUserId String
  requestedByUsername String?
  purchaseMode      RedemptionMode   @default(INDIVIDUAL)
  quantity          Int              @default(1)
  totalCost         Decimal          @db.Decimal(18, 6)
  approvalThreshold Int?
  approvalMessageChannelId String?
  approvalMessageId String?
  fulfilmentMessageChannelId String?
  fulfilmentMessageId String?
  ownerUserIdAtPurchase String?
  currencyEntryId   String?
  ledgerEntryId     String?
  stockHeld         Int?
  status            RedemptionStatus @default(PENDING)
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  guild             GuildConfig      @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  shopItem          ShopItem         @relation(fields: [shopItemId], references: [id], onDelete: Cascade)
  group             Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  requestedByParticipant Participant? @relation(fields: [requestedByParticipantId], references: [id], onDelete: SetNull)
  currencyEntry     ParticipantCurrencyEntry? @relation(fields: [currencyEntryId], references: [id], onDelete: SetNull)
  ledgerEntry       LedgerEntry?      @relation(fields: [ledgerEntryId], references: [id], onDelete: SetNull)
  approvals         ShopRedemptionApproval[]

  @@index([guildId, createdAt(sort: Desc)])
  @@index([groupId, createdAt(sort: Desc)])
  @@index([shopItemId, createdAt(sort: Desc)])
  @@index([requestedByParticipantId, createdAt(sort: Desc)])
  @@unique([currencyEntryId])
  @@unique([ledgerEntryId])
}

model MarketplaceListing {
  id                String      @id @default(cuid())
  guildId           String
  title             String
  description       String
  quantity          Int?
  createdByUserId   String
  createdByUsername String?
  channelId         String?
  messageId         String?
  active            Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  guild             GuildConfig @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  @@index([guildId, active, createdAt(sort: Desc)])
}

model AuditLog {
  id                String      @id @default(cuid())
  guildId           String
  actorUserId       String?
  actorUsername     String?
  action            String
  entityType        String
  entityId          String?
  payload           Json?
  createdAt         DateTime    @default(now())
  guild             GuildConfig @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  @@index([guildId, createdAt(sort: Desc)])
  @@index([guildId, action, createdAt(sort: Desc)])
}

model Participant {
  id              String       @id @default(cuid())
  guildId         String
  discordUserId   String
  discordUsername  String?
  indexId         String
  groupId         String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  guild           GuildConfig  @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  group           Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  submissions     Submission[]
  currencySplits  ParticipantCurrencySplit[]
  requestedShopRedemptions ShopRedemption[]
  shopRedemptionApprovals ShopRedemptionApproval[]

  @@unique([guildId, discordUserId])
  @@unique([guildId, indexId])
  @@index([guildId, groupId])
  @@index([guildId, createdAt(sort: Desc)])
}

model ParticipantCurrencyEntry {
  id                String                       @id @default(cuid())
  guildId           String
  type              ParticipantCurrencyEntryType
  description       String
  createdByUserId   String?
  createdByUsername String?
  externalRef       String?
  createdAt         DateTime                     @default(now())
  guild             GuildConfig                  @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  splits            ParticipantCurrencySplit[]
  shopRedemption    ShopRedemption?

  @@index([guildId, createdAt(sort: Desc)])
  @@index([guildId, externalRef])
}

model ParticipantCurrencySplit {
  id            String                   @id @default(cuid())
  entryId       String
  participantId String
  currencyDelta Decimal                  @db.Decimal(18, 6)
  createdAt     DateTime                 @default(now())
  entry         ParticipantCurrencyEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  participant   Participant              @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@index([participantId, createdAt(sort: Desc)])
  @@index([entryId])
}

model ShopRedemptionApproval {
  id            String         @id @default(cuid())
  redemptionId  String
  participantId String
  createdAt     DateTime       @default(now())
  redemption    ShopRedemption @relation(fields: [redemptionId], references: [id], onDelete: Cascade)
  participant   Participant    @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([redemptionId, participantId])
  @@index([participantId, createdAt(sort: Desc)])
}

model Assignment {
  id                  String       @id @default(cuid())
  guildId             String
  title               String
  description         String       @default("")
  baseCurrencyReward  Decimal      @default(0) @db.Decimal(18, 6)
  basePointsReward    Decimal      @default(0) @db.Decimal(18, 6)
  bonusCurrencyReward Decimal      @default(0) @db.Decimal(18, 6)
  bonusPointsReward   Decimal      @default(0) @db.Decimal(18, 6)
  deadline            DateTime?
  active              Boolean      @default(true)
  sortOrder           Int          @default(0)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  guild               GuildConfig  @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  submissions         Submission[]

  @@index([guildId, active, sortOrder, createdAt])
}

model Submission {
  id                  String           @id @default(cuid())
  guildId             String
  assignmentId        String
  participantId       String
  groupId             String
  text                String           @default("")
  imageUrl            String?
  imageKey            String?
  status              SubmissionStatus @default(PENDING)
  reviewedByUserId    String?
  reviewedByUsername  String?
  reviewNote          String?
  currencyAwarded     Decimal?         @db.Decimal(18, 6)
  pointsAwarded       Decimal?         @db.Decimal(18, 6)
  ledgerEntryId       String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  guild               GuildConfig      @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  assignment          Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  participant         Participant      @relation(fields: [participantId], references: [id], onDelete: Cascade)
  group               Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([guildId, assignmentId, participantId])
  @@index([guildId, createdAt(sort: Desc)])
  @@index([guildId, status, createdAt(sort: Desc)])
  @@index([guildId, assignmentId, createdAt(sort: Desc)])
  @@index([guildId, participantId, createdAt(sort: Desc)])
  @@index([guildId, groupId, createdAt(sort: Desc)])
}
