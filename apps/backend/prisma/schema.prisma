generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EconomyMode {
  SIMPLE
  ADVANCED
}

enum LedgerEntryType {
  MESSAGE_REWARD
  MANUAL_AWARD
  MANUAL_DEDUCT
  CORRECTION
  TRANSFER
  DONATION
  SHOP_REDEMPTION
  ADJUSTMENT
}

enum RedemptionStatus {
  PENDING
  FULFILLED
  CANCELED
}

model GuildConfig {
  id                           String                @id @default(cuid())
  guildId                      String                @unique
  appName                      String                @default("economy rice")
  pointsName                   String                @default("points")
  currencyName                 String                @default("rice")
  passivePointsReward          Decimal               @default(1) @db.Decimal(18, 6)
  passiveCurrencyReward        Decimal               @default(1) @db.Decimal(18, 6)
  passiveCooldownSeconds       Int                   @default(60)
  passiveMinimumCharacters     Int                   @default(4)
  passiveAllowedChannelIds     String[]              @default([])
  passiveDeniedChannelIds      String[]              @default([])
  commandLogChannelId          String?
  redemptionChannelId          String?
  listingChannelId             String?
  economyMode                  EconomyMode           @default(SIMPLE)
  createdAt                    DateTime              @default(now())
  updatedAt                    DateTime              @updatedAt
  groups                       Group[]
  roleCapabilities             DiscordRoleCapability[]
  shopItems                    ShopItem[]
  ledgerEntries                LedgerEntry[]
  marketplaceListings          MarketplaceListing[]
  shopRedemptions              ShopRedemption[]
  auditLogs                    AuditLog[]
}

model Group {
  id             String        @id @default(cuid())
  guildId        String
  displayName    String
  slug           String
  mentorName     String?
  roleId         String
  active         Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  guild          GuildConfig   @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  aliases        GroupAlias[]
  ledgerSplits   LedgerSplit[]
  shopRedemptions ShopRedemption[]

  @@unique([guildId, slug])
  @@unique([guildId, roleId])
}

model GroupAlias {
  id        String   @id @default(cuid())
  groupId    String
  value      String
  createdAt  DateTime @default(now())
  group      Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, value])
}

model DiscordRoleCapability {
  id                  String      @id @default(cuid())
  guildId             String
  roleId              String
  roleName            String
  canManageDashboard  Boolean     @default(false)
  canAward            Boolean     @default(false)
  maxAward            Decimal?    @db.Decimal(18, 6)
  canDeduct           Boolean     @default(false)
  canMultiAward       Boolean     @default(false)
  canSell             Boolean     @default(false)
  canReceiveAwards    Boolean     @default(true)
  isGroupRole         Boolean     @default(false)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  guild               GuildConfig @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  @@unique([guildId, roleId])
}

model LedgerEntry {
  id                String          @id @default(cuid())
  guildId           String
  type              LedgerEntryType
  description       String
  createdByUserId   String?
  createdByUsername String?
  externalRef       String?
  createdAt         DateTime        @default(now())
  guild             GuildConfig     @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  splits            LedgerSplit[]
}

model LedgerSplit {
  id            String      @id @default(cuid())
  entryId        String
  groupId        String
  pointsDelta    Decimal     @db.Decimal(18, 6)
  currencyDelta  Decimal     @db.Decimal(18, 6)
  createdAt      DateTime    @default(now())
  entry          LedgerEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  group          Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model ShopItem {
  id                     String            @id @default(cuid())
  guildId                String
  name                   String
  description            String
  currencyCost           Decimal           @db.Decimal(18, 6)
  stock                  Int?
  enabled                Boolean           @default(true)
  fulfillmentInstructions String?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  guild                  GuildConfig       @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  redemptions            ShopRedemption[]
}

model ShopRedemption {
  id                String           @id @default(cuid())
  guildId           String
  shopItemId        String
  groupId           String
  requestedByUserId String
  requestedByUsername String?
  quantity          Int              @default(1)
  totalCurrencyCost Decimal          @db.Decimal(18, 6)
  status            RedemptionStatus @default(PENDING)
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  guild             GuildConfig      @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  shopItem          ShopItem         @relation(fields: [shopItemId], references: [id], onDelete: Cascade)
  group             Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model MarketplaceListing {
  id                String      @id @default(cuid())
  guildId           String
  title             String
  description       String
  quantity          Int?
  createdByUserId   String
  createdByUsername String?
  channelId         String?
  messageId         String?
  active            Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  guild             GuildConfig @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
}

model AuditLog {
  id                String      @id @default(cuid())
  guildId           String
  actorUserId       String?
  actorUsername     String?
  action            String
  entityType        String
  entityId          String?
  payload           Json?
  createdAt         DateTime    @default(now())
  guild             GuildConfig @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
}
