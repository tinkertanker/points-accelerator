# economy rice production configuration
# Copy to .env.production on the server and fill in the secrets.

APP_DOMAIN=pointsbot.tk.sg
APP_EMAIL=hello@tk.sg

GUILD_ID=your-discord-guild-id
PUBLIC_APP_NAME=economy rice

PORT=3001
POSTGRES_DB=economyrice
POSTGRES_USER=economyrice
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://economyrice:change-me@postgres:5432/economyrice

DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_GUILD_ID=
ADMIN_TOKEN=change-me-now
MESSAGE_REWARD_COOLDOWN_SECONDS=60

# Frontend and backend are served from the same public host.
VITE_API_BASE_URL=/api

