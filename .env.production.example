# points accelerator production configuration
# Copy to .env.production on the server and fill in the secrets.

APP_DOMAIN=points-accelerator.tk.sg
APP_EMAIL=hello@tk.sg
APP_PUBLIC_URL=https://points-accelerator.tk.sg

GUILD_ID=your-discord-guild-id
PUBLIC_APP_NAME=points accelerator

PORT=3001
POSTGRES_DB=pointsaccelerator
POSTGRES_USER=pointsaccelerator
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://pointsaccelerator:change-me@postgres:5432/pointsaccelerator
# Optional: keep this on the legacy volume name during the first rename deploy if you are reusing existing data.
# If you reuse the old Postgres data directory, keep DATABASE_URL / POSTGRES_DB / POSTGRES_USER aligned with the legacy database and role until you rename them explicitly.
POSTGRES_VOLUME_NAME=points-accelerator-postgres

DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_APPLICATION_ID=your-discord-application-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_GUILD_ID=your-discord-guild-id
MESSAGE_REWARD_COOLDOWN_SECONDS=60

# Frontend and backend are served from the same public host.
VITE_API_BASE_URL=/api
